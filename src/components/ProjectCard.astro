---
import type { Project } from "../data/projects";
import type { Locale } from "../i18n/index";
import Pill from "./ui/Pill.astro";

interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
---

<article
  class="rounded-xl border border-neutral-100 bg-white p-6 shadow-sm hover:shadow-md transition-shadow duration-200"
>
  <h3 class="mb-3 text-lg font-semibold tracking-tight text-neutral-900">
    {project.name}
  </h3>
  <p class="mb-5 text-sm text-neutral-500 leading-relaxed">
    {project.description[locale]}
  </p>
  <ul class="mb-4 flex flex-wrap gap-2" aria-label="Tech stack">
    {project.stack.map((tag) => (
      <li>
        <Pill label={tag} />
      </li>
    ))}
  </ul>
  <div class="flex flex-wrap gap-3 text-sm">
    {project.liveUrl && (
      <a
        href={project.liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-700 underline underline-offset-2 hover:text-neutral-900 transition-colors"
      >
        Live
      </a>
    )}
    {project.repos && project.repos.map((repo) => (
      <a
        href={repo.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-700 underline underline-offset-2 hover:text-neutral-900 transition-colors"
      >
        {repo.label}
      </a>
    ))}
  </div>
</article>
