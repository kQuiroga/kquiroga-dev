---
import type { Project } from "../data/projects";
import type { Locale } from "../i18n/index";

interface Props {
  project: Project;
  locale: Locale;
  featured?: boolean;
  index: number;
}

const { project, locale, featured = false, index } = Astro.props;
---

{featured && (
  <article
    class="rounded-none border p-8 transition-colors hover:border-[var(--color-ink)]"
    style="background-color: var(--color-surface); border-color: var(--color-border); border-left: 4px solid var(--color-accent);"
  >
    <span class="mb-3 block font-mono text-xs" style="color: var(--color-ink-muted);">
      {String(index + 1).padStart(2, '0')}
    </span>
    <h3
      class="mb-3 text-2xl font-bold tracking-tight"
      style="font-family: var(--font-display); color: var(--color-ink);"
    >
      {project.name}
    </h3>
    <p class="mb-5 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
      {project.description[locale]}
    </p>
    <p class="mb-5 font-mono text-xs" style="color: var(--color-ink-muted);">{project.stack.join(' · ')}</p>
    <div class="flex flex-wrap gap-3 text-sm">
      {project.liveUrl && (
        <a
          href={project.liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition-colors"
          style="color: var(--color-ink-soft);"
        >
          Live
        </a>
      )}
      {project.repos && project.repos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition-colors"
          style="color: var(--color-ink-soft);"
        >
          {repo.label}
        </a>
      ))}
    </div>
  </article>
)}

{!featured && (
  <article
    class="rounded-none border bg-white p-6 transition-colors hover:border-[var(--color-ink)]"
    style="border-color: var(--color-border);"
  >
    <span class="mb-3 block font-mono text-xs" style="color: var(--color-ink-muted);">
      {String(index + 1).padStart(2, '0')}
    </span>
    <h3
      class="mb-3 text-lg font-semibold tracking-tight"
      style="color: var(--color-ink);"
    >
      {project.name}
    </h3>
    <p class="mb-5 text-sm leading-relaxed" style="color: var(--color-ink-soft);">
      {project.description[locale]}
    </p>
    <p class="mb-4 font-mono text-xs" style="color: var(--color-ink-muted);">{project.stack.join(' · ')}</p>
    <div class="flex flex-wrap gap-3 text-sm">
      {project.liveUrl && (
        <a
          href={project.liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition-colors"
          style="color: var(--color-ink-soft);"
        >
          Live
        </a>
      )}
      {project.repos && project.repos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition-colors"
          style="color: var(--color-ink-soft);"
        >
          {repo.label}
        </a>
      ))}
    </div>
  </article>
)}
