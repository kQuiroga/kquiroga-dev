---
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
}

const { id, title, eyebrow } = Astro.props;
---

{eyebrow && (
  <p class="text-sm uppercase tracking-wide text-neutral-400 mb-2">{eyebrow}</p>
)}
<h2 id={`${id}-heading`} class="text-3xl sm:text-4xl font-bold tracking-tighter text-neutral-900 mb-12">
  {title}
</h2>
