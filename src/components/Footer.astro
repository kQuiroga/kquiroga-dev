---
import type { TranslationShape } from '../i18n/en';

interface Props {
  t: TranslationShape['footer'];
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-100 px-6 py-8">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-3 text-sm text-neutral-500 sm:flex-row"
  >
    <p>© {year} Kevin Quiroga</p>
    <p>
      {t.credit}
    </p>
  </div>
</footer>
