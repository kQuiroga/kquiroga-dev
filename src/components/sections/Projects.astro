---
import SectionHeading from "../ui/SectionHeading.astro";
import ProjectCard from "../ProjectCard.astro";
import { projects } from "../../data/projects";
import type { Locale, Translations } from "../../i18n/index";

interface Props {
  locale: Locale;
  t: Translations['projects'];
}

const { locale, t } = Astro.props;

const featured = projects.filter(p => p.featured);
const standard = projects.filter(p => !p.featured);
---

<section id="projects" aria-labelledby="projects-heading" class="reveal bg-white px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <SectionHeading id="projects" title={t.heading} />

    <!-- Featured projects — full-width stacked block -->
    {featured.length > 0 && (
      <div class="mb-10 flex flex-col gap-6">
        {featured.map((p, i) => (
          <ProjectCard project={p} locale={locale} featured={true} index={i} />
        ))}
      </div>
    )}

    <!-- Standard projects grid — only renders when non-featured projects exist -->
    {standard.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {standard.map((p, i) => (
          <ProjectCard project={p} locale={locale} featured={false} index={featured.length + i} />
        ))}
      </div>
    )}
  </div>
</section>
