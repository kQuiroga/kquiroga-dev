---
import SectionHeading from "../ui/SectionHeading.astro";
import ProjectCard from "../ProjectCard.astro";
import { projects } from "../../data/projects";
import type { Locale, Translations } from "../../i18n/index";

interface Props {
  locale: Locale;
  t: Translations['projects'];
}

const { locale, t } = Astro.props;
---

<section id="projects" aria-labelledby="projects-heading" class="reveal bg-white px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <SectionHeading id="projects" title={t.heading} />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <ProjectCard project={p} locale={locale} />
      ))}
    </div>
  </div>
</section>
