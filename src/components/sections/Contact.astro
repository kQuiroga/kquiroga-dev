---
import SectionHeading from "../ui/SectionHeading.astro";
import Icon from "../ui/Icon.astro";
import { socials } from "../../data/socials";
import type { TranslationShape } from '../../i18n/en';

interface Props {
  t: TranslationShape['contact'];
}

const { t } = Astro.props;
---

<section id="contact" aria-labelledby="contact-heading" class="reveal bg-white px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <SectionHeading id="contact" title={t.heading} />
    <div class="max-w-2xl">
      <p class="mb-8 text-base sm:text-lg leading-relaxed text-ink-soft">
        {t.intro}
      </p>
      <!-- CTA email button — accent placement #4 -->
      <a
        href="mailto:kevin.quiroga.sanchez@gmail.com"
        class="inline-block rounded-md px-5 py-2.5 text-sm font-medium text-white bg-accent hover:bg-accent-strong transition-colors mb-10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
      >
        {t.emailCta}
      </a>
      <!-- Social icon + shortLabel row -->
      <ul class="flex flex-wrap gap-5">
        {socials.map((s) => (
          <li>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="inline-flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors font-mono"
            >
              <Icon name={s.icon} size={16} />
              {s.shortLabel}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
