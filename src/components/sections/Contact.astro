---
import SectionHeading from "../ui/SectionHeading.astro";
import { socials } from "../../data/socials";
import type { TranslationShape } from '../../i18n/en';

interface Props {
  t: TranslationShape['contact'];
}

const { t } = Astro.props;
---

<section id="contact" aria-labelledby="contact-heading" class="reveal bg-white px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <SectionHeading id="contact" title={t.heading} />
    <div class="max-w-2xl">
      <p class="mb-8 text-base sm:text-lg text-neutral-600">
        {t.intro}
      </p>
      <a
        href="mailto:kevin.quiroga.sanchez@gmail.com"
        class="inline-block rounded-md bg-neutral-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-neutral-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900 focus-visible:ring-offset-2 mb-10"
      >
        {t.emailCta}
      </a>
      <ul class="flex flex-wrap gap-4">
        {socials.map((s) => (
          <li>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="text-sm text-neutral-600 underline underline-offset-2 hover:text-neutral-900 transition-colors"
            >
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
