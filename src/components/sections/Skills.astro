---
import SectionHeading from "../ui/SectionHeading.astro";
import Pill from "../ui/Pill.astro";
import { skillGroups } from "../../data/skills";
import type { TranslationShape } from '../../i18n/en';

interface Props {
  t: TranslationShape['skills'];
}

const { t } = Astro.props;
---

<section id="skills" aria-labelledby="skills-heading" class="reveal bg-neutral-50 px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <SectionHeading id="skills" title={t.heading} />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {skillGroups.map((group) => (
        <div>
          <h3 class="mb-3 text-sm font-semibold text-neutral-900 uppercase tracking-wide">
            {group.category}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <li>
                <Pill label={skill} />
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
