---
import type { TranslationShape } from '../../i18n/en';
import Icon from '../ui/Icon.astro';
import { socials } from '../../data/socials';

interface Props {
  t: TranslationShape['hero'];
}

const { t } = Astro.props;

const manifestLines = [
  { key: 'whoami', text: t.manifest.whoami },
  { key: 'name', text: t.manifest.name },
  { key: 'role', text: t.manifest.role },
  { key: 'location', text: t.manifest.location },
  { key: 'focus', text: t.manifest.focus },
  { key: 'status', text: t.manifest.status },
];
---

<section class="flex min-h-screen flex-col justify-center px-6 pt-14">
  <div class="mx-auto max-w-5xl w-full">
    <!-- Name eyebrow — slightly larger, mono, soft -->
    <p class="mb-4 font-mono text-base text-ink-soft">Kevin Quiroga</p>

    <!-- Tagline — Fraunces light, more restrained -->
    <h1 class="mb-10 font-display font-light text-2xl sm:text-3xl leading-snug tracking-tight text-ink">
      {t.tagline}
    </h1>

    <!-- Typed manifest block — SSR-rendered, full text always in DOM -->
    <pre
      data-manifest
      class="mb-8 font-mono text-sm leading-relaxed overflow-x-auto"
      style="color: var(--color-ink);"
      aria-label="Developer manifest"
    >{manifestLines.filter(l => l.key !== 'name').map((line, i, arr) => (
      <span
        data-line
        data-text={line.text}
        class="block"
      >{line.text}{i === arr.length - 1 && (
        <span class="caret" aria-hidden="true">▮</span>
      )}</span>
    ))}</pre>

    <!-- Social icon links -->
    <div class="mb-10 flex items-center gap-5">
      {socials.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="inline-flex items-center gap-2 font-mono text-sm transition-colors"
          style="color: var(--color-ink-muted);"
        >
          <Icon name={s.icon} size={16} />
          {s.shortLabel}
        </a>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-3">
      <!-- Primary CTA — neutral-900 fill (accent reserved for hero caret only) -->
      <a
        href="#projects"
        class="rounded-md px-6 py-3 text-sm font-medium text-white transition-colors hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
        style="background-color: var(--color-ink);"
      >
        {t.primaryCta}
      </a>
      <!-- Secondary CTA — ghost -->
      <a
        href="#contact"
        class="rounded-md border px-6 py-3 text-sm font-medium transition-colors hover:border-current hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
        style="border-color: var(--color-border); color: var(--color-ink-soft);"
      >
        {t.secondaryCta}
      </a>
    </div>
  </div>
</section>

<script>
  (function () {
    if (
      'IntersectionObserver' in window &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      const pre = document.querySelector('[data-manifest]');
      if (!pre) return;

      const lines = pre.querySelectorAll<HTMLElement>('[data-line]');
      let delay = 0;

      lines.forEach((line, idx) => {
        const text = line.dataset.text || '';
        const isLast = idx === lines.length - 1;

        // Capture the caret span if on last line
        const caretSpan = isLast ? line.querySelector('.caret') : null;

        // Clear text content (keep caret span in DOM for last line)
        if (isLast && caretSpan) {
          line.textContent = '';
          line.appendChild(caretSpan);
        } else {
          line.textContent = '';
        }

        setTimeout(() => {
          let i = 0;
          const tick = setInterval(() => {
            i++;
            if (isLast && caretSpan) {
              // Insert text node before caret
              caretSpan.remove();
              line.textContent = text.slice(0, i);
              line.appendChild(caretSpan);
            } else {
              line.textContent = text.slice(0, i);
            }
            if (i >= text.length) clearInterval(tick);
          }, 28);
        }, delay);

        delay += text.length * 28 + 120;
      });
    }
  })();
</script>
